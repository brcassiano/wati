# =============================================================================
# WATI Agent Configuration
# =============================================================================

# --- WATI API ---
WATI_BASE_URL=https://live-mt-server.wati.io
WATI_API_TOKEN=your_wati_bearer_token_here

# --- LLM Provider (Primary: Qwen3 via OpenRouter) ---
LLM_MODEL=openrouter/qwen/qwen3-30b-a3b
OPENROUTER_API_KEY=sk-or-...

# --- LLM Fallbacks (tried in order if primary fails) ---
LLM_FALLBACK_MODELS=anthropic/claude-sonnet-4-20250514,openrouter/openai/gpt-4.1

# --- Fallback API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Agent Behavior ---
WATI_USE_MOCK_API=false
WATI_DRY_RUN_DEFAULT=true
WATI_LOG_LEVEL=INFO
